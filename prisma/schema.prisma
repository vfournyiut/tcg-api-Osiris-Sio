generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PokemonType {
  Normal
  Fire
  Water
  Electric
  Grass
  Ice
  Fighting
  Poison
  Ground
  Flying
  Psychic
  Bug
  Rock
  Ghost
  Dragon
  Dark
  Steel
  Fairy
}

model Card {
  id            Int         @id @default(autoincrement())
  name          String
  hp            Int
  attack        Int
  type          PokemonType
  pokedexNumber Int
  imgUrl        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deckCard DeckCard[] // Une Card peut être dans plusieurs Decks via DeckCard (N:M)
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deck Deck[] // Un User peut avoir plusieurs Decks (1:N)
}

model Deck {
  id        Int      @id @default(autoincrement())
  name      String   
  user      User     @relation(fields: [userId], references: [id])
  userId    Int      // Clé étrangère vers User
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deckCard DeckCard[] // Un Deck contient plusieurs Cards via DeckCard (N:M)
}

model DeckCard {
  id     Int  @id @default(autoincrement())
  deck   Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  deckId Int  // Clé étrangère vers Deck
  card   Card @relation(fields: [cardId], references: [id])
  cardId Int  // Clé étrangère vers Card
}